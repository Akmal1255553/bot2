APP_NAME=ai-media-telegram-bot
LOG_LEVEL=INFO
TIMEZONE=UTC
LOG_FILE_PATH=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

BOT_TOKEN=1234567890:replace_with_bot_token
PROVIDER_TOKEN=
ADMIN_IDS_RAW=123456789
CURRENCY=USD
USDT_TRC20_WALLET=

DATABASE_URL=postgresql+asyncpg://botuser:STRONG_PASSWORD_HERE@localhost:5432/ai_bot

# Stability AI provider
STABILITY_API_KEY=replace_with_stability_api_key

# Stability pricing guard
STABILITY_CREDIT_PRICE_USD=0.005
STABILITY_MAX_IMAGE_COST_USD=0.015
STABILITY_CORE_CREDITS=3.0

# Prompt and safety
REQUEST_TIMEOUT_SECONDS=60
PROVIDER_TIMEOUT_RETRIES=2
GENERATION_MAX_PROMPT_LEN=350
BANNED_WORDS_RAW=nsfw,terrorism,gore

# Plans
FREE_IMAGES_DEFAULT=3
BASIC_MONTHLY_IMAGES=50
PRO_MONTHLY_IMAGES=200
BASIC_PLAN_PRICE_USDT=2.99
PRO_PLAN_PRICE_USDT=6.99
SUBSCRIPTION_DAYS=30
REFERRAL_BONUS_IMAGES=2

# Budget protection
PER_USER_RATE_LIMIT_SECONDS=10
REQUEST_WINDOW_SECONDS=60
FREE_REQUEST_WINDOW_LIMIT=6
PAID_REQUEST_WINDOW_LIMIT=25
GLOBAL_RATE_LIMIT_REQUESTS=150
GLOBAL_RATE_LIMIT_PERIOD_SECONDS=10
GLOBAL_GENERATION_CONCURRENCY=2
DAILY_GLOBAL_GENERATION_CAP=500
